# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment out the following line if so.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if Pippile.lock is VCS-ignored, pipenv install will
#   install the dependencies from Pipfile.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact versions of dependencies.
#   It can be VCS-ignored or not.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact versions of dependencies.
#pdm.lock
.pdm-python
.pdm-db/

# PEP 582; used by e.g. pdm
